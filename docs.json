{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Loopscale",
  "colors": {
    "primary": "#276ED6",
    "light": "#F8F9FB",
    "dark": "#151619"
  },
  "favicon": "/static/assets/favicon.svg",
  "icons": {
    "library": "fontawesome"
  },
  "fonts": {
    "heading": {
      "family": "ABC Diatype Unlicensed Trial",
      "source": "https://loopscale-site.s3.us-east-1.amazonaws.com/fonts/ABCDiatype-Bold-Trial.woff",
      "weight": 600,
      "format": "woff"
    },
    "body": {
      "family": "ABC Diatype Unlicensed Trial",
      "source": "https://loopscale-site.s3.us-east-1.amazonaws.com/fonts/ABCDiatype-Regular-Trial.woff",
      "weight": 400,
      "format": "woff"
    }
  },
  "appearance": { "default": "light", "strict": true },
  "navigation": {
    "versions": [
      {
        "version": "Curator Documentation",
        "groups": [
          {
            "group": "Loopscale Vaults",
            "pages": ["docs/using-loopscale/loopscale-vaults/vault-curation"]
          }
        ]
      },
      {
        "version": "Public Documentation",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "docs/introduction/overview",
              "docs/introduction/why-loopscale"
            ]
          },
          {
            "group": "Using Loopscale",
            "pages": [
              {
                "group": "Loopscale Vaults",
                "pages": [
                  "docs/using-loopscale/loopscale-vaults/loopscale-vaults",
                  "docs/using-loopscale/loopscale-vaults/vault-curation"
                ]
              },
              "docs/using-loopscale/yield-loops",
              {
                "group": "Borrowing",
                "pages": [
                  "docs/using-loopscale/borrowing/borrowing-assets",
                  "docs/using-loopscale/borrowing/managing-loans",
                  "docs/using-loopscale/borrowing/using-lp-collateral"
                ]
              },
              {
                "group": "Advanced Lending",
                "pages": [
                  "docs/using-loopscale/advanced-lending/lending-assets",
                  "docs/using-loopscale/advanced-lending/managing-positions"
                ]
              },
              "docs/using-loopscale/points"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "docs/concepts/loans",
              "docs/concepts/credit-order-book",
              "docs/concepts/loops"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "docs/resources/risks-and-security",
              "docs/resources/asset-parameters",
              "docs/resources/faq",
              "docs/resources/audits",
              "docs/resources/brand-kit"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/static/assets/logo/light.svg",
    "dark": "/static/assets/logo/dark.svg",
    "href": "https://loopscale.com"
  },
  "navbar": {
    "links": [
      {
        "label": "Blog",
        "href": "https://blog.loopscale.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://app.loopscale.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/LoopscaleLabs",
      "github": "https://github.com/LoopscaleLabs",
      "linkedin": "https://linkedin.com/company/LoopscaleLabs"
    }
  }
}
